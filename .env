# Local development database (native Postgres started by the dev environment).
# In production on Vercel, Vercel Postgres injects this automatically.
DATABASE_URL="postgresql://wcadmin:wcadmin@localhost:5432/worldcup?schema=public"

# Single admin password gating the /admin area and admin APIs.
ADMIN_PASSWORD="kickoff-2026"

# Secret used to sign the cron trigger (Vercel Cron sends this).
CRON_SECRET="dev-cron-secret"
